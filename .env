# MongoDB connection (Docker: mongodb://mongo:27017/propcore | local: mongodb://localhost:27017/propcore)
MONGODB_URI=mongodb://mongo:27017/propcore

# Google Gemini API key – required for maintenance triage and semantic search (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Server port
PORT=3000

# CORS: comma-separated allowed origins in production (e.g. https://myapp.vercel.app). Leave empty to allow any origin (dev only).
# CORS_ORIGIN=https://your-frontend.vercel.app
